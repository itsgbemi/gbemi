rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { 
      return request.resource.data; 
    }
    
    // Validation Blueprint for Contact Submission
    function isValidContactSubmission(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // Fortified constraints
    match /contact_submissions/{submissionId} {
      // No reads allowed from client side.
      allow read, update, delete: if false;
      
      // Anyone can submit a contact form as long as the payload strictly adheres to the schema
      allow create: if isValidId(submissionId) && isValidContactSubmission(incoming());
    }
  }
}
